{
  "name": "book-management-system",
  "version": "1.0.0",
  "description": "本地书籍库存管理桌面应用",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"npx wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^5.22.0",
    "better-sqlite3": "^11.6.0",
    "drizzle-orm": "^0.36.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.33.5",
    "uuid": "^11.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "fast-check": "^4.7.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.bookmanagement.app",
    "productName": "书籍管理系统",
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
